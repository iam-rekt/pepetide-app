export async function generateNowPaymentsInvoice(orderId: string) {
    const order = await getOrder(orderId)
    if (!order) throw new Error("Order not found")

    // Clean up SITE_URL to ensure it is a valid base for URI construction
    const rawUrl = process.env.NEXT_PUBLIC_SITE_URL || 'https://www.universalpeptide.com'
    const siteUrl = rawUrl.trim().replace(/[\n\r\t]/g, '').replace(/\/+$/, '')

    try {
        const invoiceData = {
            price_amount: Number(order.total),
            price_currency: 'eur',
            order_id: order.id,
            order_description: `Order #${order.id.slice(0, 8).toUpperCase()} - Universal Peptide`,
            ipn_callback_url: `${siteUrl}/api/webhooks/nowpayments`,
            success_url: `${siteUrl}/order/${order.id}?payment=success`,
            cancel_url: `${siteUrl}/checkout?payment=cancelled`,
        }

        console.log("[NOWPayments] Creating invoice with data:", JSON.stringify(invoiceData, null, 2))

        const invoice = await createNowPaymentsInvoice(invoiceData)

        return { invoiceUrl: invoice.invoice_url }
    } catch (error: any) {
        console.error("[generateNowPaymentsInvoice] Error details:", error)
        throw new Error(error.message || "Failed to create crypto invoice")
    }
}

