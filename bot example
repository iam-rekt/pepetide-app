export async function validateCoupon(code: string, currentTotal?: number) {
    try {
        const coupon = await (prisma as any).coupon.findUnique({
            where: { code: code.toUpperCase() }
        })

        if (!coupon) {
            return { valid: false, message: "Invalid coupon code" }
        }

        if (!coupon.isActive) {
            return { valid: false, message: "Coupon is no longer active" }
        }

        if (coupon.minSpend && currentTotal && currentTotal < Number(coupon.minSpend)) {
            return { valid: false, message: `Minimum spend of ${formatCurrency(Number(coupon.minSpend))} required.` }
        }

        return {
            valid: true,
            discount: coupon.discount,
            code: coupon.code,
            type: coupon.type,
            message: coupon.type === 'FREE_SHIPPING'
                ? "Free shipping applied!"
                : `Coupon applied: ${coupon.type === 'FIXED' ? formatCurrency(coupon.discount) : coupon.discount + '%'} off!`
        }
    } catch (error) {
        console.error("Error validating coupon:", error)
        return { valid: false, message: "Error determining coupon validity" }
    }
}

