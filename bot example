export async function updateOrderStatuses(
    orderId: string,
    data: {
        paymentStatus: string,
        fulfillmentStatus: string,
        riskStatus: string,
        trackingCode?: string,
        trackingUrl?: string,
        internalNotes?: string
    }
) {
    try {
        const existing = await prisma.order.findUnique({
            where: { id: orderId },
            select: {
                id: true,
                customerEmail: true,
                customerName: true,
                paidAt: true,
                confirmedAt: true,
                shippedAt: true,
                paymentStatus: true,
                fulfillmentStatus: true
            } as any
        }) as any

        const updateData: any = {
            paymentStatus: data.paymentStatus,
            fulfillmentStatus: data.fulfillmentStatus,
            riskStatus: data.riskStatus,
            trackingCode: data.trackingCode,
            trackingUrl: data.trackingUrl,
            internalNotes: data.internalNotes
        }

        // --- Logic for status synchronization ---

        // Initial state is "Processing" (from createOrder)

        // 1. Payment Confirmation -> "Payment Received"
        if (data.paymentStatus === "PAID" && !existing?.paidAt) {
            updateData.paidAt = new Date()
            updateData.status = "Payment Received"

            if (!existing?.confirmedAt) {
                updateData.confirmedAt = new Date()
                // Send Order Confirmed Email (Awaited)
                try {
                    await sendEmail({
                        to: existing.customerEmail,
                        subject: `Payment Received - Order #${existing.id.slice(0, 8).toUpperCase()}`,
                        react: <OrderConfirmedEmail
                            orderId={ existing.id.slice(0, 8).toUpperCase() }
                            customerName = { existing.customerName }
                        />
                    });
            } catch (err) {
                console.error("Failed to send order confirmed email:", err);
            }
        }
    }

        // 2. Shipment -> "Shipped"
        if (data.fulfillmentStatus === "FULFILLED" && existing?.fulfillmentStatus !== "FULFILLED") {
        updateData.shippedAt = new Date()
        updateData.status = "Shipped"

        // Send Order Shipped Email (Awaited)
        if (data.trackingCode) {
            try {
                await sendEmail({
                    to: existing.customerEmail,
                    subject: `Order Shipped #${existing.id.slice(0, 8).toUpperCase()}`,
                    react: <OrderShippedEmail
                            orderId={ existing.id.slice(0, 8).toUpperCase() }
                            customerName = { existing.customerName }
                            trackingCode = { data.trackingCode }
                            trackingUrl = { data.trackingUrl }
                    />
                    });
        } catch (err) {
            console.error("Failed to send order shipped email:", err);
        }
    }
}

// 3. Refund -> "Refunded"
if (data.paymentStatus === "REFUNDED" && existing?.paymentStatus !== "REFUNDED") {
    updateData.status = "Refunded"
    // Send Refund Email (Awaited)
    try {
        await sendEmail({
            to: existing.customerEmail,
            subject: `Order Refunded #${existing.id.slice(0, 8).toUpperCase()}`,
            react: <OrderRefundedEmail
                        orderId={ existing.id.slice(0, 8).toUpperCase() }
                        customerName = { existing.customerName }
            />
                });
} catch (err) {
    console.error("Failed to send refund email:", err);
}
        }

// 4. Cancel -> "Canceled"
if (data.fulfillmentStatus === "CANCELED" && existing?.fulfillmentStatus !== "CANCELED") {
    updateData.status = "Canceled"
}

await prisma.order.update({
    where: { id: orderId },
    data: updateData
})

revalidatePath('/admin/orders')
revalidatePath(`/admin/orders/${orderId}`)
revalidatePath(`/order/${orderId}`)
return { success: true }
    } catch (error) {
    console.error("Error updating order statuses:", error)
    return { success: false, error: "Failed to update statuses" }
}
}

